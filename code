const { useState, useMemo, useRef, useEffect, useCallback } = React;

/* =========================================================================
   INLINE SUM / PROD — register rawArgs functions so sum() and prod() can
   be nested inside any expression (e.g. 1 + sum(...), sum(sum(...), ...))
   and can reference slider variables from the enclosing evaluation scope.
   ========================================================================= */
(function registerInlineFunctions() {
  // Build a rawArgs loop function (sum or product).
  // We mutate the live scope (set/restore) so that nested calls can see outer
  // loop variables — e.g. the inner j-loop sees i from the outer i-loop.
  function makeLoopFn(fnName, initVal, combine) {
    const fn = function(args, _math, scope) {
      if (args.length !== 4) throw new Error(fnName + "(expr, var, start, end): requires 4 arguments");
      const varNode = args[1];
      if (!varNode || typeof varNode.name !== "string") throw new Error(fnName + ": second argument must be a variable name");
      const varName = varNode.name;
      const start = Math.round(args[2].evaluate(scope));
      const end   = Math.round(args[3].evaluate(scope));
      if (!isFinite(start) || !isFinite(end)) throw new Error(fnName + ": start/end must be finite numbers");
      if (Math.abs(end - start) > 1e5) throw new Error(fnName + ": range too large (max 100k terms)");
      const compiled = args[0].compile();
      // Save/restore the loop variable in the shared scope so nested
      // sum/prod calls can read outer variables (e.g. inner j sees outer i).
      const hadVar   = scope.has(varName);
      const savedVal = hadVar ? scope.get(varName) : undefined;
      let acc = initVal;
      try {
        for (let k = start; k <= end; k++) {
          scope.set(varName, k);
          const v = compiled.evaluate(scope);
          if (typeof v !== "number" || !isFinite(v)) throw new Error(fnName + ": non-numeric term at " + varName + "=" + k);
          acc = combine(acc, v);
        }
      } finally {
        if (hadVar) scope.set(varName, savedVal);
        else scope.delete(varName);
      }
      return acc;
    };
    fn.rawArgs = true;
    return fn;
  }
  math.import({
    sum:  makeLoopFn("sum",  0, (a, b) => a + b),
    prod: makeLoopFn("prod", 1, (a, b) => a * b),
  }, { override: true });
})();

/* =========================================================================
   MATH UTILITIES
   ========================================================================= */

function computeCoeffs(compiled, a, numTerms, r = 0.5, N = 1024, extraScope = {}) {
  const fRe = new Float64Array(N);
  const fIm = new Float64Array(N);
  const TWO_PI_OVER_N = (2 * Math.PI) / N;
  // Pre-compute cos/sin table for DFT to avoid redundant trig calls
  const cosTable = new Float64Array(N);
  const sinTable = new Float64Array(N);
  for (let k = 0; k < N; k++) {
    const theta = TWO_PI_OVER_N * k;
    cosTable[k] = Math.cos(theta);
    sinTable[k] = Math.sin(theta);
    const zRe = a + r * cosTable[k];
    const zIm = r * sinTable[k];
    try {
      const val = compiled.evaluate({ x: math.complex(zRe, zIm), ...extraScope });
      if (typeof val === "number")         { fRe[k] = val;    fIm[k] = 0; }
      else if (val != null && "re" in val) { fRe[k] = val.re; fIm[k] = val.im; }
      else                                 { fRe[k] = NaN;    fIm[k] = 0; }
    } catch(e) { fRe[k] = NaN; fIm[k] = NaN; }
  }
  const coeffs = new Array(numTerms);
  let rPow = 1;
  for (let n = 0; n < numTerms; n++) {
    let re = 0;
    for (let k = 0; k < N; k++) {
      if (!isFinite(fRe[k])) continue;
      // angle = -TWO_PI_OVER_N * n * k — use trig identities with precomputed table
      const nk = (n * k) % N;
      const cosA = cosTable[nk];
      const sinA = -sinTable[nk]; // negative angle
      re += fRe[k] * cosA - fIm[k] * sinA;
    }
    coeffs[n] = re / (N * rPow);
    rPow *= r;
    if (!isFinite(coeffs[n])) { coeffs[n] = 0; } // guard against underflow/overflow
  }
  return coeffs;
}

function evalPoly(coeffs, a, x) {
  const dx = x - a;
  let sum = 0;
  for (let i = coeffs.length - 1; i >= 0; i--) sum = sum * dx + coeffs[i];
  return sum;
}

function derivCoeffs(coeffs) {
  const d = [];
  for (let n = 0; n < coeffs.length - 1; n++) d.push((n + 1) * coeffs[n + 1]);
  return d;
}

function integCoeffs(coeffs) {
  const ig = [0];
  for (let n = 0; n < coeffs.length; n++) ig.push(coeffs[n] / (n + 1));
  return ig;
}

function niceStep(target) {
  const p = Math.pow(10, Math.floor(Math.log10(Math.abs(target) || 1)));
  const f = target / p;
  return p * (f < 1.5 ? 1 : f < 3.5 ? 2 : f < 7.5 ? 5 : 10);
}

function fmt(n) {
  if (n === 0) return "0";
  const a = Math.abs(n);
  if (a >= 1e4 || a < 5e-3) return n.toExponential(1);
  return +n.toPrecision(3) + "";
}

/* =========================================================================
   RK4 ODE SOLVER
   ========================================================================= */

function solveODE_RK4(fExpr, x0, y0, xMin, xMax, h = 0.01) {
  let compiled;
  try { compiled = math.compile(fExpr); } catch(e) { return []; /* invalid expression — return empty solution */ }
  const f = (x, y) => {
    try {
      const v = compiled.evaluate({ x, y });
      return typeof v === "number" ? v : NaN;
    } catch(e) { return NaN; }
  };
  const pts = [{ x: x0, y: y0 }];
  let x = x0, y = y0;
  while (x < xMax + h) {
    const k1 = f(x, y);
    const k2 = f(x + h/2, y + h*k1/2);
    const k3 = f(x + h/2, y + h*k2/2);
    const k4 = f(x + h, y + h*k3);
    if (!isFinite(k1) || !isFinite(k2) || !isFinite(k3) || !isFinite(k4)) break;
    y += (h/6) * (k1 + 2*k2 + 2*k3 + k4);
    x += h;
    if (!isFinite(y)) break;
    pts.push({ x, y });
  }
  x = x0; y = y0;
  const backPts = [];
  while (x > xMin - h) {
    const k1 = f(x, y);
    const k2 = f(x - h/2, y - h*k1/2);
    const k3 = f(x - h/2, y - h*k2/2);
    const k4 = f(x - h, y - h*k3);
    if (!isFinite(k1) || !isFinite(k2) || !isFinite(k3) || !isFinite(k4)) break;
    y -= (h/6) * (k1 + 2*k2 + 2*k3 + k4);
    x -= h;
    if (!isFinite(y)) break;
    backPts.push({ x, y });
  }
  backPts.reverse();
  return [...backPts, ...pts];
}

/* =========================================================================
   CALCULUS ENGINE — symbolic & numerical methods
   Supports: derivatives, integrals, limits, sums, products, equation solving
   ========================================================================= */

// Adaptive Simpson's rule for numerical integration
function adaptiveSimpson(f, a, b, tol, maxDepth) {
  if (!isFinite(a) || !isFinite(b)) return NaN;
  tol = tol || 1e-10;
  maxDepth = maxDepth || 30;
  function simpson(a, b) {
    const c = (a + b) / 2;
    const fa = f(a), fc = f(c), fb = f(b);
    if (!isFinite(fa) || !isFinite(fc) || !isFinite(fb)) return NaN;
    return ((b - a) / 6) * (fa + 4 * fc + fb);
  }
  function recurse(a, b, whole, depth) {
    const c = (a + b) / 2;
    const left = simpson(a, c);
    const right = simpson(c, b);
    if (!isFinite(left) || !isFinite(right)) return (isFinite(left) ? left : 0) + (isFinite(right) ? right : 0);
    if (depth >= maxDepth || Math.abs(left + right - whole) <= 15 * tol) {
      return left + right + (left + right - whole) / 15;
    }
    return recurse(a, c, left, depth + 1) + recurse(c, b, right, depth + 1);
  }
  if (a === b) return 0;
  if (a > b) return -adaptiveSimpson(f, b, a, tol, maxDepth);
  const whole = simpson(a, b);
  if (!isFinite(whole)) return NaN;
  return recurse(a, b, whole, 0);
}

// Numerical limit via Richardson extrapolation
function numericalLimit(f, target, side) {
  // side: 0=both, 1=right, -1=left
  side = side || 0;
  if (!isFinite(target)) return NaN;
  function limitFromSide(dir) {
    const hs = [];
    const vals = [];
    // Use moderate step sizes to avoid catastrophic cancellation
    for (let k = 1; k <= 20; k++) {
      const h = dir * Math.pow(0.5, k);
      try {
        const v = f(target + h);
        if (!isFinite(v)) continue;
        hs.push(Math.abs(h));
        vals.push(v);
      } catch(e) { continue; }
    }
    if (vals.length < 3) return NaN;
    // Check direct convergence of raw values first (handles oscillatory functions)
    const last3 = vals.slice(-3);
    const spread = Math.max(...last3) - Math.min(...last3);
    const directVal = vals[vals.length - 1];
    // Richardson extrapolation table
    let table = vals.slice();
    let bestLen = table.length;
    for (let j = 1; j < table.length; j++) {
      const next = [];
      for (let i = 0; i < table.length - j; i++) {
        const r = hs[i] / hs[i + j];
        if (Math.abs(r - 1) < 1e-15) continue; // avoid division by zero
        const val = (r * table[i + 1] - table[i]) / (r - 1);
        if (isFinite(val)) next.push(val);
      }
      if (next.length === 0) break;
      table = next;
      if (table.length <= 1) break;
    }
    const richVal = (table.length > 0 && isFinite(table[0])) ? table[0] : NaN;
    // If Richardson diverged (result far from raw values), prefer direct convergence
    if (isFinite(richVal) && spread < 0.1 * (1 + Math.abs(directVal))) {
      if (Math.abs(richVal - directVal) > 10 * spread) return directVal;
    }
    return isFinite(richVal) ? richVal : (isFinite(directVal) ? directVal : NaN);
  }
  if (side > 0) return limitFromSide(1);
  if (side < 0) return limitFromSide(-1);
  const left = limitFromSide(-1);
  const right = limitFromSide(1);
  if (!isFinite(left) && !isFinite(right)) return NaN;
  if (!isFinite(left)) return right;
  if (!isFinite(right)) return left;
  if (Math.abs(left - right) < 1e-8 * (1 + Math.abs(left))) return (left + right) / 2;
  return NaN; // limit doesn't exist (left ≠ right)
}

// Newton-Raphson equation solver: find roots of f(x) = 0
function solveEquation(exprText) {
  let lhs = exprText, rhs = "0";
  if (exprText.includes("=")) {
    const parts = exprText.split("=");
    lhs = parts[0].trim();
    rhs = parts[1].trim();
  }
  const diffExpr = "(" + lhs + ")-(" + rhs + ")";
  let compiled;
  try { compiled = math.compile(diffExpr); } catch(e) { return { err: e.message }; }
  const f = x => { try { const v = compiled.evaluate({ x }); return typeof v === "number" ? v : NaN; } catch(e) { return NaN; } };

  // Try symbolic derivative for Newton's method
  let df;
  try {
    const dNode = math.derivative(diffExpr, "x");
    const dCompiled = dNode.compile ? dNode.compile() : math.compile(dNode.toString());
    df = x => { try { const v = dCompiled.evaluate({ x }); return typeof v === "number" ? v : NaN; } catch(e) { return NaN; } };
  } catch(e) {
    // Fallback: numerical derivative
    df = x => (f(x + 1e-8) - f(x - 1e-8)) / 2e-8;
  }

  const roots = [];
  const seen = new Set();
  // Scan range [-20, 20] for sign changes and try Newton from multiple starting points
  const starts = [];
  for (let x = -20; x <= 20; x += 0.25) starts.push(x);
  // Also add points where sign changes
  let prevVal = f(-20);
  for (let x = -19.9; x <= 20; x += 0.1) {
    const val = f(x);
    if (isFinite(prevVal) && isFinite(val) && prevVal * val < 0) {
      // Bisection to narrow down
      let lo = x - 0.1, hi = x;
      for (let i = 0; i < 60; i++) {
        const mid = (lo + hi) / 2;
        const fm = f(mid);
        if (!isFinite(fm)) break;
        const flo = f(lo);
        if (!isFinite(flo)) break;
        if (flo * fm < 0) hi = mid; else lo = mid;
      }
      const root = (lo + hi) / 2;
      const key = root.toFixed(8);
      if (!seen.has(key) && Math.abs(f(root)) < 1e-6) {
        seen.add(key);
        roots.push(root);
      }
    }
    prevVal = val;
  }
  // Newton-Raphson from various starting points
  for (const x0 of starts) {
    let x = x0;
    for (let i = 0; i < 100; i++) {
      const fx = f(x);
      const dfx = df(x);
      if (!isFinite(fx) || !isFinite(dfx) || Math.abs(dfx) < 1e-15) break;
      const xNew = x - fx / dfx;
      if (!isFinite(xNew)) break;
      if (Math.abs(xNew - x) < 1e-12) { x = xNew; break; }
      x = xNew;
    }
    if (isFinite(x) && Math.abs(f(x)) < 1e-8) {
      const key = x.toFixed(8);
      if (!seen.has(key)) { seen.add(key); roots.push(x); }
    }
  }
  roots.sort((a, b) => a - b);
  return { roots };
}

// Preprocess expression text to handle calculus syntax before math.compile
// Supported: diff(...), integrate(...), limit(...), sum(...), prod(...), solve(...)
// scope: optional slider variable values used to evaluate sum/prod bounds
function preprocessCalculus(text, scope) {
  const evalScope = scope || {};
  const trimmed = text.trim();

  // diff(expr, var) or diff(expr, var, n) — symbolic derivative
  let m = trimmed.match(/^diff\((.+),\s*([a-z]),?\s*(\d+)?\)$/i);
  if (m) {
    try {
      let node = math.parse(m[1]);
      const v = m[2];
      const n = parseInt(m[3] || "1");
      for (let i = 0; i < n; i++) node = math.derivative(node, v);
      const simplified = math.simplify(node);
      return { type: "symbolic", label: n > 1 ? `d${n}/d${v}${n}` : `d/d${v}`, result: simplified.toString() };
    } catch(e) { return { type: "error", result: e.message }; }
  }

  // d/dx(...) — symbolic derivative shorthand
  m = trimmed.match(/^d\/d([a-z])\((.+)\)$/i);
  if (m) {
    try {
      const node = math.derivative(m[2], m[1]);
      const simplified = math.simplify(node);
      return { type: "symbolic", label: `d/d${m[1]}`, result: simplified.toString() };
    } catch(e) { return { type: "error", result: e.message }; }
  }

  // integrate(expr, var, a, b) — definite integral
  m = trimmed.match(/^integrate\((.+),\s*([a-z]),\s*(.+),\s*(.+)\)$/i);
  if (!m) m = trimmed.match(/^int\((.+),\s*([a-z]),\s*(.+),\s*(.+)\)$/i);
  if (m) {
    try {
      const compiled = math.compile(m[1]);
      const vName = m[2];
      const a = math.evaluate(m[3]);
      const b = math.evaluate(m[4]);
      if (!isFinite(a) || !isFinite(b)) return { type: "error", result: "Invalid bounds: must be finite numbers" };
      const f = t => { try { const v = compiled.evaluate({ [vName]: t }); return typeof v === "number" ? v : NaN; } catch(e) { return NaN; } };
      const result = adaptiveSimpson(f, a, b);
      return { type: "numeric", label: `∫[${m[3]},${m[4]}]`, result };
    } catch(e) { return { type: "error", result: e.message }; }
  }

  // limit(expr, var, target) or limit(expr, var, target, side)
  m = trimmed.match(/^limit\((.+),\s*([a-z]),\s*(.+?)(?:,\s*(left|right|[+-]?[01]))?\)$/i);
  if (!m) m = trimmed.match(/^lim\((.+),\s*([a-z]),\s*(.+?)(?:,\s*(left|right|[+-]?[01]))?\)$/i);
  if (m) {
    try {
      const compiled = math.compile(m[1]);
      const vName = m[2];
      const target = math.evaluate(m[3]);
      let side = 0;
      if (m[4]) {
        const s = m[4].toLowerCase();
        if (s === "right" || s === "1" || s === "+1") side = 1;
        else if (s === "left" || s === "-1") side = -1;
      }
      const f = t => { try { const v = compiled.evaluate({ [vName]: t }); return typeof v === "number" ? v : NaN; } catch(e) { return NaN; } };
      const result = numericalLimit(f, target, side);
      return { type: "numeric", label: `lim(${vName}→${m[3]})`, result };
    } catch(e) { return { type: "error", result: e.message }; }
  }

  // sum(expr, var, start, end) — summation
  m = trimmed.match(/^sum\((.+),\s*([a-z]),\s*(.+),\s*(.+)\)$/i);
  if (m) {
    try {
      const compiled = math.compile(m[1]);
      const vName = m[2];
      const start = Math.round(math.evaluate(m[3], evalScope));
      const end = Math.round(math.evaluate(m[4], evalScope));
      if (Math.abs(end - start) > 1e7) return { type: "error", result: "Sum range too large (max 10M terms)" };
      let total = 0;
      for (let i = start; i <= end; i++) {
        const v = compiled.evaluate({ ...evalScope, [vName]: i });
        if (typeof v === "number") total += v;
        else return { type: "error", result: "Non-numeric term in sum" };
      }
      return { type: "numeric", label: `Σ(${vName}=${start}..${end})`, result: total };
    } catch(e) { return { type: "error", result: e.message }; }
  }

  // prod(expr, var, start, end) — product
  m = trimmed.match(/^prod\((.+),\s*([a-z]),\s*(.+),\s*(.+)\)$/i);
  if (m) {
    try {
      const compiled = math.compile(m[1]);
      const vName = m[2];
      const start = Math.round(math.evaluate(m[3], evalScope));
      const end = Math.round(math.evaluate(m[4], evalScope));
      if (Math.abs(end - start) > 1e7) return { type: "error", result: "Product range too large (max 10M terms)" };
      let total = 1;
      for (let i = start; i <= end; i++) {
        const v = compiled.evaluate({ ...evalScope, [vName]: i });
        if (typeof v === "number") total *= v;
        else return { type: "error", result: "Non-numeric term in product" };
      }
      return { type: "numeric", label: `Π(${vName}=${start}..${end})`, result: total };
    } catch(e) { return { type: "error", result: e.message }; }
  }

  // solve(expr) or solve(lhs = rhs) — find real roots
  m = trimmed.match(/^solve\((.+)\)$/i);
  if (m) {
    const result = solveEquation(m[1]);
    if (result.err) return { type: "error", result: result.err };
    if (result.roots.length === 0) return { type: "solve", label: "solve", roots: [], result: "No real solutions found" };
    return { type: "solve", label: "solve", roots: result.roots,
      result: "x = " + result.roots.map(r => {
        if (Math.abs(r) < 1e-12) return "0";
        if (Number.isInteger(r)) return r.toString();
        return r.toPrecision(10).replace(/\.?0+$/, "");
      }).join(", ") };
  }

  // simplify(expr) — symbolic simplification
  m = trimmed.match(/^simplify\((.+)\)$/i);
  if (m) {
    try {
      const simplified = math.simplify(m[1]);
      return { type: "symbolic", label: "simplify", result: simplified.toString() };
    } catch(e) { return { type: "error", result: e.message }; }
  }

  // expand(expr) — symbolic expansion via rationalize
  m = trimmed.match(/^expand\((.+)\)$/i);
  if (m) {
    try {
      const expanded = math.rationalize(m[1]);
      return { type: "symbolic", label: "expand", result: expanded.toString() };
    } catch(e) { return { type: "error", result: e.message }; }
  }

  // Equation with = sign (not inside a function call) — auto-solve
  if (trimmed.includes("=") && !trimmed.match(/^(diff|integrate|int|limit|lim|sum|prod|solve|simplify|expand)\(/i)) {
    const result = solveEquation(trimmed);
    if (result.err) return null; // fall through to normal evaluation
    if (result.roots.length > 0) {
      return { type: "solve", label: "solve", roots: result.roots,
        result: "x = " + result.roots.map(r => {
          if (Math.abs(r) < 1e-12) return "0";
          if (Number.isInteger(r)) return r.toString();
          return r.toPrecision(10).replace(/\.?0+$/, "");
        }).join(", ") };
    }
  }

  return null; // not a calculus expression — use normal evaluation
}

/* =========================================================================
   MATH OCR — recognize math from uploaded images
   Uses Tesseract.js for OCR + post-processing for math syntax
   ========================================================================= */

// Preprocess an image for better OCR accuracy:
// - Scales up small images (Tesseract works best at ~300 DPI)
// - Converts to grayscale and binarizes (black text on white background)
// - Auto-inverts dark-mode screenshots so text is always dark-on-light
async function preprocessImageForOCR(imageFile) {
  return new Promise((resolve, reject) => {
    const img = new Image();
    const url = URL.createObjectURL(imageFile);
    img.onload = () => {
      URL.revokeObjectURL(url);
      const canvas = document.createElement("canvas");
      // Scale up to at least 1200px on the longest side for better OCR
      const maxDim = Math.max(img.width, img.height);
      const scale = maxDim < 1200 ? Math.min(3, 1200 / maxDim) : 1;
      canvas.width  = Math.round(img.width  * scale);
      canvas.height = Math.round(img.height * scale);
      const ctx = canvas.getContext("2d");
      // White background so transparent PNGs don't become black
      ctx.fillStyle = "#ffffff";
      ctx.fillRect(0, 0, canvas.width, canvas.height);
      ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
      const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
      const data = imageData.data;
      // Compute average brightness to detect dark-mode screenshots
      let brightnessSum = 0;
      for (let i = 0; i < data.length; i += 4) {
        brightnessSum += 0.299 * data[i] + 0.587 * data[i + 1] + 0.114 * data[i + 2];
      }
      const avgBrightness = brightnessSum / (canvas.width * canvas.height);
      // 128 = midpoint of the 0-255 range; below that the image is mostly dark
      // (i.e. a dark-mode screenshot where text is light on dark background).
      const isDark = avgBrightness < 128;
      // Binarize: convert to pure black (text) or white (background).
      // Threshold 160 (rather than 128) keeps more stroke pixels black and
      // avoids dropping thin/antialiased characters to white too early.
      for (let i = 0; i < data.length; i += 4) {
        let gray = 0.299 * data[i] + 0.587 * data[i + 1] + 0.114 * data[i + 2];
        if (isDark) gray = 255 - gray;  // invert dark-mode so text becomes dark
        const val = gray < 160 ? 0 : 255;
        data[i] = data[i + 1] = data[i + 2] = val;
        data[i + 3] = 255;
      }
      ctx.putImageData(imageData, 0, 0);
      canvas.toBlob(blob => resolve(blob), "image/png");
    };
    img.onerror = () => { URL.revokeObjectURL(url); reject(new Error("Failed to load image")); };
    img.src = url;
  });
}

function postProcessMathOCR(raw) {
  let t = raw.trim();
  // Normalize common OCR misreads and Unicode symbols
  t = t.replace(/\u00d7/g, "*");      // ×
  t = t.replace(/\u00f7/g, "/");      // ÷
  t = t.replace(/\u2212/g, "-");      // −
  t = t.replace(/\u2013/g, "-");      // –
  t = t.replace(/\u2014/g, "-");      // —
  t = t.replace(/\u00b2/g, "^2");     // ²
  t = t.replace(/\u00b3/g, "^3");     // ³
  t = t.replace(/\u221a/g, "sqrt");   // √
  t = t.replace(/\u03c0/g, "pi");     // π
  t = t.replace(/\u03b8/g, "x");      // θ → x
  t = t.replace(/\u222b/g, "integrate"); // ∫
  t = t.replace(/\u03a3/g, "sum");    // Σ
  t = t.replace(/\u03a0/g, "prod");   // Π
  t = t.replace(/\u221e/g, "Infinity"); // ∞
  // Common OCR misreads
  t = t.replace(/\bIn\b/g, "ln");     // OCR reads 'ln' as 'In' (capital-I + n)
  t = t.replace(/\bIog\b/gi, "log");  // Iog → log
  t = t.replace(/\bSin\b/g, "sin");
  t = t.replace(/\bCos\b/g, "cos");
  t = t.replace(/\bTan\b/g, "tan");
  t = t.replace(/\bExp\b/g, "exp");
  t = t.replace(/\bSqrt\b/g, "sqrt");
  t = t.replace(/\bAbs\b/g, "abs");
  t = t.replace(/[{}[\]]/g, c => c === "{" || c === "[" ? "(" : ")");
  // Remove stray characters
  t = t.replace(/[|\\]/g, "");
  // Strip newlines (PSM 6 may produce multi-line output; join into one line)
  t = t.replace(/[\r\n]+/g, " ");
  // Collapse whitespace
  t = t.replace(/\s+/g, " ").trim();
  // Implicit multiplication: 2x → 2*x, )x → )*x, )( → )*(
  t = t.replace(/(\d)([a-zA-Z(])/g, "$1*$2");
  t = t.replace(/\)(\()/g, ")*(");
  t = t.replace(/\)([a-zA-Z])/g, ")*$1");
  return t;
}

async function recognizeMathFromImage(imageFile) {
  if (typeof Tesseract === "undefined") {
    return { error: "Tesseract.js not loaded" };
  }
  try {
    const processedBlob = await preprocessImageForOCR(imageFile);
    const worker = await Tesseract.createWorker("eng", 1, {
      corePath: "https://unpkg.com/tesseract.js-core@5.1.0/tesseract-core-simd-lstm.wasm.js",
      workerPath: "https://unpkg.com/tesseract.js@5.1.1/dist/worker.min.js",
    });
    await worker.setParameters({
      tessedit_char_whitelist: "0123456789abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ+-*/^().,=<>! ",
      tessedit_pageseg_mode: "6",
    });
    const { data } = await worker.recognize(processedBlob);
    await worker.terminate();
    const raw = data.text || "";
    const processed = postProcessMathOCR(raw);
    return { raw, processed };
  } catch(e) {
    return { error: e.message || "OCR failed" };
  }
}

