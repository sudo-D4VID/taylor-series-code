  const displayCoeffs = firstData ? firstData.coeffs : null;
  const focusedData = exprData.find(e => e.id === focusedId);

  // Syntax reference data
  const syntaxData = [
    ["Arithmetic",  "+  \u2212  *  /  ^  **  %"],
    ["Powers",      "x^2  x^(1/3)  2^x  e^(-x^2)"],
