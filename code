/* =========================================================================
   GRAPH COMPONENT (multi-function + ODE) — wrapped in React.memo
   ========================================================================= */

const Graph = React.memo(function Graph({ exprData, center, evalX, numTerms, showDeriv, showInteg, showDeriv2,
                  taylorEnabled, odeCurve, odeVisible, theme }) {
  const canvasRef = useRef(null);
  const viewRef   = useRef({ cx: 0, cy: 0, scale: 80 });
  const dragRef   = useRef(null);
  const rafRef    = useRef(null);

  const redraw = useCallback(() => {
    const cv = canvasRef.current;
    if (!cv) return;
    const ctx = cv.getContext("2d");
    if (!ctx) return;
    const W = cv.width, H = cv.height;
    if (W === 0 || H === 0) return;
    const { cx, cy, scale: S } = viewRef.current;

    const sx = wx => (wx - cx) * S + W / 2;
    const sy = wy => H / 2 - (wy - cy) * S;
    const wx = px => (px - W / 2) / S + cx;
    const wy = py => (H / 2 - py) / S + cy;

    const t = theme;

    ctx.fillStyle = t.bg;
    ctx.fillRect(0, 0, W, H);

    // Grid
    const step = niceStep(100 / S);
    const x0 = Math.floor(wx(0) / step) * step;
    const y0 = Math.floor(wy(H) / step) * step;
    ctx.lineWidth = 1;
    ctx.strokeStyle = t.gridLine;
    ctx.beginPath();
    for (let gx = x0; gx < wx(W) + step; gx += step) {
      ctx.moveTo(sx(gx), 0); ctx.lineTo(sx(gx), H);
    }
    for (let gy = y0; gy < wy(0) + step; gy += step) {
      ctx.moveTo(0, sy(gy)); ctx.lineTo(W, sy(gy));
    }
    ctx.stroke();

    // Axes
    const axY = Math.max(1, Math.min(H - 1, sy(0)));
    const axX = Math.max(1, Math.min(W - 1, sx(0)));
    ctx.strokeStyle = t.axis; ctx.lineWidth = 1.5;
    ctx.beginPath(); ctx.moveTo(0, axY); ctx.lineTo(W, axY); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(axX, 0); ctx.lineTo(axX, H); ctx.stroke();

    // Arrows
    ctx.fillStyle = t.axis;
    ctx.beginPath(); ctx.moveTo(W-2,axY); ctx.lineTo(W-11,axY-5); ctx.lineTo(W-11,axY+5); ctx.fill();
    ctx.beginPath(); ctx.moveTo(axX,2); ctx.lineTo(axX-5,11); ctx.lineTo(axX+5,11); ctx.fill();

    // Axis labels
    ctx.fillStyle = t.axisLabel;
    ctx.font = "bold 10px Consolas, 'Courier New', monospace";
    ctx.textAlign = "center";
    for (let gx = x0; gx < wx(W) + step; gx += step) {
      if (Math.abs(gx) < step * 0.01) continue;
      ctx.fillText(fmt(gx), sx(gx), Math.min(axY + 14, H - 3));
    }
    ctx.textAlign = "right";
    for (let gy = y0; gy < wy(0) + step; gy += step) {
      if (Math.abs(gy) < step * 0.01) continue;
      ctx.fillText(fmt(gy), Math.max(axX - 5, 30), sy(gy) + 3);
    }

    // Plot helper
    const plotFn = (fn, color, lw, dash) => {
      ctx.strokeStyle = color;
      ctx.lineWidth = lw;
      ctx.setLineDash(dash || []);
      ctx.beginPath();
      let pen = false, prevPy = null;
      const SAMPLES = W * 2;
      for (let i = 0; i <= SAMPLES; i++) {
        const px = (i / SAMPLES) * W;
        const wX = wx(px);
        let wY;
        try { wY = fn(wX); } catch(e) { pen = false; prevPy = null; continue; }
        if (!isFinite(wY)) { pen = false; prevPy = null; continue; }
        const pY = sy(wY);
        if (prevPy !== null && Math.abs(pY - prevPy) > H * 1.5) { pen = false; }
        if (!pen) { ctx.moveTo(px, pY); pen = true; }
        else ctx.lineTo(px, pY);
        prevPy = pY;
      }
      ctx.stroke();
      ctx.setLineDash([]);
    };

    // Plot each visible expression
    exprData.forEach(ed => {
      if (!ed.visible) return;
      if (ed.realFn) plotFn(ed.realFn, ed.color, 2.5);
      if (ed.showTaylor && taylorEnabled && ed.coeffs && ed.coeffs.length) {
        const cc = ed.coeffs, cn = center;
        plotFn(x => evalPoly(cc, cn, x), ed.color + "80", 2, [8, 4]);
      }
      if (showDeriv && ed.dCoeffs && ed.dCoeffs.length) {
        const cc = ed.dCoeffs, cn = center;
        plotFn(x => evalPoly(cc, cn, x), t.derivColor, 1.8, [6, 3]);
      }
      if (showDeriv2 && ed.d2Coeffs && ed.d2Coeffs.length) {
        const cc = ed.d2Coeffs, cn = center;
        plotFn(x => evalPoly(cc, cn, x), t.deriv2Color, 1.5, [3, 3]);
      }
      if (showInteg && ed.iCoeffs && ed.iCoeffs.length) {
        const cc = ed.iCoeffs, cn = center;
        plotFn(x => evalPoly(cc, cn, x), t.integColor, 1.8, [8, 3, 2, 3]);
      }
    });

    // ODE curve
    if (odeVisible && odeCurve && odeCurve.length > 1) {
      ctx.strokeStyle = t.odeColor;
      ctx.lineWidth = 2.5;
      ctx.setLineDash([]);
      ctx.beginPath();
      let started = false;
      for (const pt of odeCurve) {
        if (!isFinite(pt.x) || !isFinite(pt.y)) { started = false; continue; }
        const ppx = sx(pt.x), ppy = sy(pt.y);
        if (!started) { ctx.moveTo(ppx, ppy); started = true; }
        else ctx.lineTo(ppx, ppy);
      }
      ctx.stroke();
    }

    // Center marker
    const firstVis = exprData.find(e => e.visible && e.realFn);
    if (firstVis) {
      const cval = firstVis.realFn(center);
      if (isFinite(cval)) {
        ctx.beginPath(); ctx.arc(sx(center), sy(cval), 6, 0, 6.283);
        ctx.fillStyle = t.accent3; ctx.fill();
        ctx.strokeStyle = t.centerStroke; ctx.lineWidth = 1.5; ctx.stroke();
      }
    }

    // evalX guide
    if (evalX !== null && isFinite(evalX)) {
      ctx.setLineDash([4, 4]);
      ctx.strokeStyle = t.guideColor; ctx.lineWidth = 1;
      ctx.beginPath(); ctx.moveTo(sx(evalX), 0); ctx.lineTo(sx(evalX), H); ctx.stroke();
      ctx.setLineDash([]);
    }

    // Legend
    ctx.font = "bold 11px Consolas, 'Courier New', monospace";
    ctx.textAlign = "left";
    let ly = H - 10;
    ctx.fillStyle = t.accent3; ctx.fillText("\u25cf center a", 90, ly);
    exprData.forEach(ed => {
      if (!ed.visible) return;
      ctx.fillStyle = ed.color;
      const lbl = ed.text.length > 18 ? ed.text.slice(0, 16) + "\u2026" : ed.text;
      ctx.fillText("\u25a0 " + lbl, 10, ly); ly -= 16;
    });
    if (showDeriv)  { ctx.fillStyle = t.derivColor;  ctx.fillText("\u256c f\u2032(x)", 10, ly); ly -= 16; }
    if (showDeriv2) { ctx.fillStyle = t.deriv2Color; ctx.fillText("\u00b7\u00b7 f\u2033(x)", 10, ly); ly -= 16; }
    if (showInteg)  { ctx.fillStyle = t.integColor;  ctx.fillText("\u256c \u222bf dx", 10, ly); ly -= 16; }
    if (odeVisible && odeCurve && odeCurve.length) {
      ctx.fillStyle = t.odeColor; ctx.fillText("\u25a0 ODE solution", 10, ly);
    }
  }, [exprData, center, evalX, numTerms, showDeriv, showInteg, showDeriv2, odeCurve, odeVisible, theme]);

  const schedRedraw = useCallback(() => {
    cancelAnimationFrame(rafRef.current);
    rafRef.current = requestAnimationFrame(redraw);
  }, [redraw]);

  useEffect(() => {
    const cv = canvasRef.current;
    if (!cv) return;
    const ro = new ResizeObserver(() => {
      cv.width = cv.offsetWidth; cv.height = cv.offsetHeight; schedRedraw();
    });
    ro.observe(cv);
    cv.width = cv.offsetWidth; cv.height = cv.offsetHeight;
    schedRedraw();
    return () => ro.disconnect();
  }, [schedRedraw]);

  useEffect(() => schedRedraw(), [schedRedraw]);

  const onWheel = useCallback(e => {
    e.preventDefault();
    const cv = canvasRef.current;
    if (!cv) return;
    const rect = cv.getBoundingClientRect();
    const mx = e.clientX - rect.left, my = e.clientY - rect.top;
    const { cx, cy, scale } = viewRef.current;
    if (!scale || scale <= 0) return;
    const W = cv.width, H = cv.height;
    const f = e.deltaY < 0 ? 1.2 : 0.833;
    const wMx = (mx - W/2) / scale + cx;
    const wMy = (H/2 - my) / scale + cy;
    const ns = Math.max(1e-12, Math.min(1e12, scale * f));
    viewRef.current = { cx: wMx - (mx - W/2)/ns, cy: wMy + (my - H/2)/ns, scale: ns };
    schedRedraw();
  }, [schedRedraw]);

  useEffect(() => {
    const cv = canvasRef.current;
    if (!cv) return;
    cv.addEventListener("wheel", onWheel, { passive: false });
    return () => cv.removeEventListener("wheel", onWheel);
  }, [onWheel]);

  const onDown = useCallback(e => { dragRef.current = { x: e.clientX, y: e.clientY, ...viewRef.current }; }, []);
  const onMove = useCallback(e => {
    if (!dragRef.current) return;
    const { x, y, cx, cy, scale } = dragRef.current;
    viewRef.current.cx = cx - (e.clientX - x) / scale;
    viewRef.current.cy = cy + (e.clientY - y) / scale;
    schedRedraw();
  }, [schedRedraw]);
  const onUp = useCallback(() => { dragRef.current = null; }, []);

  const canvasStyle = useMemo(() => ({ display: "block", width: "100%", height: "100%", cursor: "crosshair", touchAction: "none" }), []);

  // Touch support for mobile
  const onTouchStart = useCallback(e => {
    if (e.touches.length === 1) {
      const t = e.touches[0];
      dragRef.current = { x: t.clientX, y: t.clientY, ...viewRef.current };
    }
  }, []);
  const onTouchMove = useCallback(e => {
    e.preventDefault();
    if (!dragRef.current || e.touches.length !== 1) return;
    const t = e.touches[0];
    const { x, y, cx, cy, scale } = dragRef.current;
    viewRef.current.cx = cx - (t.clientX - x) / scale;
    viewRef.current.cy = cy + (t.clientY - y) / scale;
    schedRedraw();
  }, [schedRedraw]);
  const onTouchEnd = useCallback(() => { dragRef.current = null; }, []);

  return (
    <canvas ref={canvasRef}
      style={canvasStyle}
      onMouseDown={onDown} onMouseMove={onMove} onMouseUp={onUp} onMouseLeave={onUp}
      onTouchStart={onTouchStart} onTouchMove={onTouchMove} onTouchEnd={onTouchEnd}
    />
  );
});  // React.memo(Graph)

