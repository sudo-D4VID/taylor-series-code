                  onClick={() => setShowSliders(s => !s)}>
                  <div style={{ fontSize: ".7rem", fontWeight: 800, color: t.headerTitle,
                    letterSpacing: ".06em", textTransform: "uppercase" }}>
                    {showSliders ? "\u25bc" : "\u25b6"} Variable Sliders
                  </div>
                </div>
                {showSliders && (
                  <div style={{ display: "flex", flexDirection: "column", gap: ".4rem", paddingTop: ".2rem" }}>
                    {SLIDER_VARS.map(v => (
                      <div key={v} style={{ display: "flex", alignItems: "center", gap: ".4rem" }}>
                        <button onClick={() => updateSlider(v, { active: !sliders[v].active })}
                          style={{ width: 22, height: 22, borderRadius: "4px", cursor: "pointer",
                            background: sliders[v].active ? t.accent2 : "transparent",
                            border: `1.5px solid ${sliders[v].active ? t.accent2 : t.borderDim}`,
                            color: "#fff", fontSize: ".6rem", fontWeight: 800, fontFamily: "inherit",
                            display: "flex", alignItems: "center", justifyContent: "center" }}>
                          {sliders[v].active ? "\u2713" : ""}
                        </button>
                        <span style={{ fontSize: ".78rem", fontWeight: 700, color: t.accent3,
                          minWidth: "1rem", textAlign: "center" }}>{v}</span>
                        {sliders[v].active ? (
                          <>
                            <input type="range"
                              min={sliders[v].min} max={sliders[v].max} step="0.01"
                              value={sliders[v].value}
                              onChange={e => updateSlider(v, { value: parseFloat(e.target.value) })}
                              style={{ flex: 1, height: "4px" }} />
                            <span style={{ fontSize: ".68rem", fontWeight: 600, color: t.text,
                              minWidth: "2.5rem", textAlign: "right" }}>
                              {sliders[v].value.toFixed(2)}
                            </span>
                          </>
                        ) : (
                          <span style={{ fontSize: ".62rem", color: t.textMuted, fontWeight: 600 }}>inactive</span>
                        )}
                      </div>
                    ))}
                  </div>
                )}
              </div>

              {/* Presets */}
              <div>
                <div style={{ fontSize: ".6rem", letterSpacing: ".18em", textTransform: "uppercase",
                  color: t.lblColor, marginBottom: ".32rem", fontWeight: 700 }}>Presets</div>
                <div style={{ display: "flex", flexWrap: "wrap", gap: ".22rem" }}>
                  {PRESETS.map(([pe, pc]) => {
                    const focused = expressions.find(ex => ex.id === focusedId);
                    const isOn = focused && focused.text === pe;
                    return (
                      <span key={pe} onClick={() => applyPreset(pe, pc)}
                        style={{ display: "inline-block", padding: ".16rem .48rem", background: t.tagBg,
                          border: `1px solid ${isOn ? t.accent : t.tagBorder}`, borderRadius: "3px",
                          fontSize: ".7rem", cursor: "pointer", fontWeight: 600,
                          color: isOn ? t.accent : t.tagText }}>
                        {pe}
                      </span>
                    );
                  })}
                </div>
              </div>

              <hr style={{ border: "none", borderTop: `1px solid ${t.borderPanel}` }} />

              {/* Taylor Settings (collapsible) */}
              <div>
                <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between",
                  cursor: "pointer", userSelect: "none", padding: ".35rem 0" }}
                  onClick={() => setShowTaylorSettings(s => !s)}>
                  <div style={{ fontSize: ".7rem", fontWeight: 800, color: t.headerTitle,
                    letterSpacing: ".06em", textTransform: "uppercase" }}>
                    {showTaylorSettings ? "\u25bc" : "\u25b6"} Taylor Settings
                  </div>
                  <button
                    onClick={e => { e.stopPropagation(); setTaylorEnabled(s => !s); }}
                    title={taylorEnabled ? "Disable Taylor approximation" : "Enable Taylor approximation"}
                    style={{ background: taylorEnabled ? t.accent2 : t.panel,
                      border: `1px solid ${taylorEnabled ? t.accent2 : t.border}`,
                      borderRadius: "4px", padding: ".15rem .45rem", cursor: "pointer",
                      fontSize: ".58rem", fontWeight: 700, color: taylorEnabled ? "#fff" : t.textMuted,
                      fontFamily: "inherit" }}>
                    {taylorEnabled ? "ON" : "OFF"}
                  </button>
                </div>
                {showTaylorSettings && (
                  <div style={{ display: "flex", flexDirection: "column", gap: ".6rem", paddingTop: ".3rem" }}>
                    <div>
                      <div style={{ fontSize: ".6rem", letterSpacing: ".18em", textTransform: "uppercase",
                        color: t.lblColor, marginBottom: ".32rem", fontWeight: 700 }}>
                        Expansion center <span style={{ color: t.accent3 }}>a</span>
                      </div>
                      <input type="number" step="0.5" value={center}
                        onChange={e => setCenter(parseFloat(e.target.value) || 0)}
                        style={{ width: "100%" }} />
                    </div>
                    <div>
                      <div style={{ fontSize: ".6rem", letterSpacing: ".18em", textTransform: "uppercase",
                        color: t.lblColor, marginBottom: ".32rem", fontWeight: 700 }}>
                        Number of terms <span style={{ color: t.accent, letterSpacing: 0 }}>N = {terms}</span>
                      </div>
                      <input type="range" min="1" max="200" value={terms}
                        onChange={e => setTerms(+e.target.value)} style={{ width: "100%" }} />
                      <div style={{ display: "flex", justifyContent: "space-between",
                        fontSize: ".55rem", color: t.textMuted, marginTop: ".1rem", fontWeight: 600 }}>
                        <span>1</span><span>50</span><span>100</span><span>150</span><span>200</span>
                      </div>
                    </div>
                    <hr style={{ border: "none", borderTop: `1px solid ${t.borderPanel}` }} />
                    <div>
                      <div style={{ fontSize: ".6rem", letterSpacing: ".18em", textTransform: "uppercase",
                        color: t.lblColor, marginBottom: ".32rem", fontWeight: 700 }}>
                        Evaluate at <span style={{ color: t.accent }}>x</span> =
                      </div>
                      <input type="number" step="0.1" value={evalX}
                        onChange={e => setEvalX(parseFloat(e.target.value) || 0)}
                        style={{ width: "100%" }} />
                    </div>
                    {/* Results */}
                    {approx !== undefined && (
                      <div style={{ display: "flex", flexDirection: "column", gap: ".35rem" }}>
                        <div style={{ background: t.panel, border: `1px solid ${t.borderDim}`, borderRadius: "5px",
                          padding: ".6rem .75rem" }}>
                          <div style={{ fontSize: ".6rem", letterSpacing: ".18em", textTransform: "uppercase",
                            color: t.lblColor, marginBottom: ".12rem", fontWeight: 700 }}>Taylor T({evalX})</div>
                          <div style={{ fontSize: "1.1rem", fontWeight: 700, color: t.accent }}>
                            {isFinite(approx) ? approx.toPrecision(9) : "\u2014"}</div>
                        </div>
                        <div style={{ background: t.panel, border: `1px solid ${t.borderDim}`, borderRadius: "5px",
                          padding: ".6rem .75rem" }}>
                          <div style={{ fontSize: ".6rem", letterSpacing: ".18em", textTransform: "uppercase",
                            color: t.lblColor, marginBottom: ".12rem", fontWeight: 700 }}>Exact f({evalX})</div>
                          <div style={{ fontSize: "1.1rem", fontWeight: 700, color: t.accent2 }}>
                            {isFinite(exact) ? exact.toPrecision(9) : "\u2014"}</div>
                        </div>
                        <div style={{ background: t.panel, border: `1px solid ${t.borderDim}`, borderRadius: "5px",
                          padding: ".6rem .75rem" }}>
                          <div style={{ fontSize: ".6rem", letterSpacing: ".18em", textTransform: "uppercase",
                            color: t.lblColor, marginBottom: ".12rem", fontWeight: 700 }}>Percentage Error</div>
                          <div style={{ fontSize: "1.1rem", fontWeight: 700, color: errColor }}>
                            {!isFinite(pctErr) ? "\u2014"
                              : pctErr < 1e-10 ? "< 1\u00d710\u207b\u00b9\u2070 %"
                              : pctErr.toPrecision(4) + " %"}</div>
                        </div>
                      </div>
                    )}
                  </div>
                )}
              </div>

              <hr style={{ border: "none", borderTop: `1px solid ${t.borderPanel}` }} />

              {/* Calculus Functions */}
              <div>
                <div style={{ fontSize: ".6rem", letterSpacing: ".18em", textTransform: "uppercase",
                  color: t.lblColor, marginBottom: ".32rem", fontWeight: 700 }}>Calculus Functions</div>
                <div style={{ display: "flex", flexWrap: "wrap", gap: ".3rem", marginBottom: ".4rem" }}>
                  <span onClick={() => setShowDeriv(s => !s)}
                    style={{ display: "inline-flex", alignItems: "center", gap: ".3rem", padding: ".2rem .5rem",
                      background: t.panel, border: `1px solid ${showDeriv ? t.accent : t.borderDim}`,
                      borderRadius: "4px", fontSize: ".68rem", cursor: "pointer",
                      color: showDeriv ? t.accent : t.tagText, fontWeight: 600, userSelect: "none" }}>
                    <span style={{ color: t.derivColor }}>f{"\u2032"}(x)</span> Derivative
                  </span>
                  <span onClick={() => setShowDeriv2(s => !s)}
                    style={{ display: "inline-flex", alignItems: "center", gap: ".3rem", padding: ".2rem .5rem",
                      background: t.panel, border: `1px solid ${showDeriv2 ? t.accent : t.borderDim}`,
                      borderRadius: "4px", fontSize: ".68rem", cursor: "pointer",
                      color: showDeriv2 ? t.accent : t.tagText, fontWeight: 600, userSelect: "none" }}>
                    <span style={{ color: t.deriv2Color }}>f{"\u2033"}(x)</span> 2nd Deriv
                  </span>
                  <span onClick={() => setShowInteg(s => !s)}
                    style={{ display: "inline-flex", alignItems: "center", gap: ".3rem", padding: ".2rem .5rem",
                      background: t.panel, border: `1px solid ${showInteg ? t.accent : t.borderDim}`,
                      borderRadius: "4px", fontSize: ".68rem", cursor: "pointer",
                      color: showInteg ? t.accent : t.tagText, fontWeight: 600, userSelect: "none" }}>
                    <span style={{ color: t.integColor }}>{"\u222b"}f dx</span> Integral
                  </span>
                </div>
                {/* Calculus values */}
                {displayCoeffs && (showDeriv || showDeriv2 || showInteg) && (
                  <div style={{ display: "flex", flexDirection: "column", gap: ".3rem" }}>
                    {showDeriv && (
                      <div style={{ background: t.panel, border: `1px solid ${t.borderDim}`, borderRadius: "5px",
                        padding: ".6rem .75rem" }}>
                        <div style={{ fontSize: ".6rem", letterSpacing: ".18em", textTransform: "uppercase",
                          color: t.lblColor, marginBottom: ".12rem", fontWeight: 700 }}>
                          f{"\u2032"}({evalX}) {"\u2014"} 1st derivative</div>
                        <div style={{ fontSize: "1.1rem", fontWeight: 700, color: t.derivColor }}>
                          {isFinite(derivVal) ? derivVal.toPrecision(9) : "\u2014"}</div>
                      </div>
                    )}
                    {showDeriv2 && (
                      <div style={{ background: t.panel, border: `1px solid ${t.borderDim}`, borderRadius: "5px",
                        padding: ".6rem .75rem" }}>
                        <div style={{ fontSize: ".6rem", letterSpacing: ".18em", textTransform: "uppercase",
                          color: t.lblColor, marginBottom: ".12rem", fontWeight: 700 }}>
                          f{"\u2033"}({evalX}) {"\u2014"} 2nd derivative</div>
                        <div style={{ fontSize: "1.1rem", fontWeight: 700, color: t.deriv2Color }}>
                          {isFinite(deriv2Val) ? deriv2Val.toPrecision(9) : "\u2014"}</div>
                      </div>
                    )}
                    {showInteg && (
                      <div style={{ background: t.panel, border: `1px solid ${t.borderDim}`, borderRadius: "5px",
                        padding: ".6rem .75rem" }}>
                        <div style={{ fontSize: ".6rem", letterSpacing: ".18em", textTransform: "uppercase",
                          color: t.lblColor, marginBottom: ".12rem", fontWeight: 700 }}>
                          {"\u222b"}f dx at x={evalX} {"\u2014"} from a={center}</div>
                        <div style={{ fontSize: "1.1rem", fontWeight: 700, color: t.integColor }}>
                          {isFinite(integVal) ? integVal.toPrecision(9) : "\u2014"}</div>
                      </div>
                    )}
                  </div>
                )}
              </div>

              <hr style={{ border: "none", borderTop: `1px solid ${t.borderPanel}` }} />

              {/* ODE Mode */}
              <div>
                <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between",
                  cursor: "pointer", userSelect: "none", padding: ".35rem 0" }}
                  onClick={() => setOdeMode(s => !s)}>
                  <div style={{ fontSize: ".7rem", fontWeight: 800, color: t.headerTitle,
                    letterSpacing: ".06em", textTransform: "uppercase" }}>
                    {odeMode ? "\u25bc" : "\u25b6"} ODE Mode
                  </div>
                  <div style={{ fontSize: ".58rem", color: t.odeColor, fontWeight: 700 }}>
                    {odeMode ? "ON" : "OFF"}
                  </div>
                </div>
                {odeMode && (
                  <div style={{ display: "flex", flexDirection: "column", gap: ".5rem", paddingTop: ".3rem" }}>
                    <div>
                      <div style={{ fontSize: ".6rem", letterSpacing: ".18em", textTransform: "uppercase",
                        color: t.lblColor, marginBottom: ".32rem", fontWeight: 700 }}>
                        dy/dx = f(x, y)
                      </div>
                      <input value={odeExpr} onChange={e => setOdeExpr(e.target.value)}
                        placeholder="e.g. -y + sin(x)" style={{ width: "100%", fontSize: ".85rem" }} />
                    </div>
                    <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: ".4rem" }}>
                      <div>
                        <div style={{ fontSize: ".6rem", letterSpacing: ".18em", textTransform: "uppercase",
                          color: t.lblColor, marginBottom: ".32rem", fontWeight: 700 }}>x{"\u2080"}</div>
                        <input type="number" step="0.5" value={odeX0}
                          onChange={e => setOdeX0(parseFloat(e.target.value) || 0)}
                          style={{ width: "100%" }} />
                      </div>
                      <div>
                        <div style={{ fontSize: ".6rem", letterSpacing: ".18em", textTransform: "uppercase",
                          color: t.lblColor, marginBottom: ".32rem", fontWeight: 700 }}>y(x{"\u2080"}) = y{"\u2080"}</div>
                        <input type="number" step="0.5" value={odeY0}
                          onChange={e => setOdeY0(parseFloat(e.target.value) || 0)}
                          style={{ width: "100%" }} />
                      </div>
                    </div>
                    <div style={{ display: "flex", alignItems: "center", gap: ".5rem" }}>
                      <button onClick={() => setOdeVisible(s => !s)}
                        style={{ background: "none", border: "none", cursor: "pointer",
                          color: odeVisible ? t.odeColor : t.textMuted, fontSize: ".8rem", padding: ".15rem" }}>
                        {odeVisible ? "\ud83d\udc41" : "\ud83d\udc41\u200d\ud83d\udde8"}
                      </button>
                      <span style={{ fontSize: ".65rem", fontWeight: 600, color: t.textDim }}>
                        RK4 solution ({odeCurve.length} pts)
                      </span>
                    </div>
                  </div>
                )}
              </div>

              <hr style={{ border: "none", borderTop: `1px solid ${t.borderPanel}` }} />

              {/* Syntax Reference */}
              <div>
                <div style={{ fontSize: ".6rem", letterSpacing: ".18em", textTransform: "uppercase",
                  color: t.lblColor, marginBottom: ".32rem", fontWeight: 700,
                  cursor: "pointer", userSelect: "none" }}
                  onClick={() => setShowSyntax(s => !s)}>
                  {showSyntax ? "\u25bc" : "\u25b6"} Syntax Reference
                </div>
                {showSyntax && (
                  <div style={{ fontSize: ".7rem", color: t.textDim, lineHeight: 2, marginTop: ".4rem", fontWeight: 600 }}>
                    {syntaxData.map(([k, v]) => (
                      <div key={k}>
                        <span style={{ color: t.accent, fontWeight: 700 }}>{k}:</span> {v}
                      </div>
                    ))}
                    <div style={{ marginTop: ".4rem", color: t.textMuted, fontWeight: 700 }}>Examples:</div>
                    {syntaxExamples.map(ex => (
                      <div key={ex} style={{ color: t.accent2, paddingLeft: ".5rem" }}>{"\u2192"} {ex}</div>
                    ))}
                  </div>
                )}
              </div>

            </div>
          </div>
        </div>

        {/* RIGHT: graph + coeff strip */}
        <div style={{ display: "flex", flexDirection: "column", minHeight: 0 }}>
          <div style={{ flex: 1, position: "relative", minHeight: 0 }}>
            <Graph exprData={exprData} center={center} evalX={evalX} numTerms={terms}
              showDeriv={showDeriv} showInteg={showInteg} showDeriv2={showDeriv2}
              taylorEnabled={taylorEnabled}
              odeCurve={odeCurve} odeVisible={odeMode && odeVisible}
              theme={t} />
            <div style={{ position: "absolute", top: 8, right: 10, fontSize: ".58rem",
              color: t.hintColor, textAlign: "right", pointerEvents: "none", fontWeight: 600 }}>
              scroll to zoom {"\u00b7"} drag to pan
            </div>
          </div>
          {/* Coefficient strip */}
          {displayCoeffs && (
            <div style={{ borderTop: `1px solid ${t.borderPanel}`, padding: ".45rem .8rem",
              overflowX: "auto", flexShrink: 0, maxHeight: "110px" }}>
              <div style={{ fontSize: ".6rem", letterSpacing: ".18em", textTransform: "uppercase",
                color: t.lblColor, marginBottom: ".35rem", fontWeight: 700 }}>
                Coefficients c{"\u2099"} = f{"\u207d\u207f\u207e"}(a) / n!
              </div>
              <div style={{ display: "flex", gap: ".28rem", flexWrap: "wrap" }}>
                {displayCoeffs.map((c, n) => (
                  <div key={n} style={{ background: t.panel, border: `1px solid ${t.borderDim}`,
                    borderRadius: "4px", padding: ".22rem .5rem", fontSize: ".68rem",
                    whiteSpace: "nowrap", fontWeight: 600 }}>
                    <span style={{ color: t.accent3 }}>c{n}</span>
                    <span style={{ color: t.borderDim }}>=</span>
                    <span style={{ color: Math.abs(c) < 1e-12 ? t.dimCoeff : t.accent }}>
                      {Math.abs(c) < 1e-13 ? "0" : c.toPrecision(4)}
                    </span>
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  );
}

const root = ReactDOM.createRoot(document.getElementById("root"));
root.render(<TaylorApp />);
