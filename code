  const [showSyntax,         setShowSyntax]         = useState(false);
  const [showKeyboard,       setShowKeyboard]       = useState(false);
  const [showTaylorSettings, setShowTaylorSettings] = useState(true);
  const [taylorEnabled,      setTaylorEnabled]      = useState(true);
  const [themeMode,          setThemeMode]          = useState("dark");
  const [showDeriv,          setShowDeriv]          = useState(false);
  const [showDeriv2,         setShowDeriv2]         = useState(false);
  const [showInteg,          setShowInteg]          = useState(false);

  const [odeMode,    setOdeMode]    = useState(false);
  const [odeExpr,    setOdeExpr]    = useState("y");
  const [odeX0,      setOdeX0]      = useState(0);
  const [odeY0,      setOdeY0]      = useState(1);
  const [odeVisible, setOdeVisible] = useState(true);

  // Variable sliders: a-v (excluding x, y, z, w which stay as free variables)
  const SLIDER_VARS = "a,b,c,d,f,g,h,k,m,n,p,q,r,s,t,u,v".split(",");
  const [sliders, setSliders] = useState(() => {
    const init = {};
    SLIDER_VARS.forEach(v => { init[v] = { value: 1, min: -10, max: 10, active: false }; });
    return init;
  });
  const [showSliders, setShowSliders] = useState(false);

  const updateSlider = (v, updates) => {
    setSliders(prev => ({ ...prev, [v]: { ...prev[v], ...updates } }));
  };

  // Build slider scope for expression evaluation
  const sliderScope = useMemo(() => {
    const scope = {};
    SLIDER_VARS.forEach(v => { if (sliders[v].active) scope[v] = sliders[v].value; });
    return scope;
  }, [sliders]);

  // OCR image upload state
  const [ocrLoading, setOcrLoading] = useState(false);
  const fileInputRef = useRef(null);

  const handleImageUpload = async (file) => {
    if (!file) return;
    setOcrLoading(true);
    try {
      const result = await recognizeMathFromImage(file);
      if (result.error) {
        alert("OCR Error: " + result.error);
      } else if (result.processed) {
        if (focusedId) {
          updateExpr(focusedId, { text: result.processed });
        } else {
          // Add new expression with OCR text directly via functional state update
          setExpressions(prev => {
            const id = nextExpressionId++;
            const color = COLOR_PALETTE[(prev.length) % COLOR_PALETTE.length];
            return [...prev, { id, text: result.processed, color, visible: true, showTaylor: true }];
          });
        }
      }
    } catch(e) {
      alert("OCR failed: " + e.message);
    }
    setOcrLoading(false);
  };

  const t = THEMES[themeMode];

  const addExpression = () => {
    const id = nextExpressionId++;
    const colorIdx = expressions.length % COLOR_PALETTE.length;
    setExpressions(prev => [...prev, {
      id, text: "", color: COLOR_PALETTE[colorIdx], visible: true, showTaylor: true
    }]);
    setFocusedId(id);
  };

  const removeExpression = (id) => {
    if (expressions.length <= 1) return;
    setExpressions(prev => prev.filter(e => e.id !== id));
  };

  const updateExpr = (id, updates) => {
    setExpressions(prev => prev.map(e => e.id === id ? { ...e, ...updates } : e));
  };

  const applyPreset = (text, c) => {
    if (focusedId) updateExpr(focusedId, { text });
    setCenter(c);
  };

  const handleKeyboardKey = (insert) => {
    const el = inputRefs.current[focusedId];
    if (!el) return;
    const start = el.selectionStart || 0;
    const end = el.selectionEnd || 0;
    const currentExpr = expressions.find(e => e.id === focusedId);
    if (!currentExpr) return;
    const txt = currentExpr.text;
    if (insert === "__BACKSPACE__") {
      if (start > 0) {
        const newText = txt.slice(0, start - 1) + txt.slice(end);
        updateExpr(focusedId, { text: newText });
        const pos = start - 1;
        setTimeout(() => { if (el && el.parentNode) { try { el.focus(); el.setSelectionRange(pos, pos); } catch(e) {} } }, 0);
      }
      return;
    }
    const newText = txt.slice(0, start) + insert + txt.slice(end);
    updateExpr(focusedId, { text: newText });
    const newPos = start + insert.length;
    setTimeout(() => { if (el && el.parentNode) { try { el.focus(); el.setSelectionRange(newPos, newPos); } catch(e) {} } }, 0);
  };

  // Compile all expressions (with calculus engine + slider variables)
  const exprData = useMemo(() => {
    return expressions.map(expr => {
      let compiled = null, realFn = null, parseErr = null;
      let isPlainEq = false, plainResult = null;
      let calculusResult = null;
      if (expr.text.trim()) {
        // First try calculus engine (diff, integrate, limit, sum, solve, etc.)
        calculusResult = preprocessCalculus(expr.text, sliderScope);
        if (calculusResult) {
          isPlainEq = true;
          plainResult = calculusResult;
        } else {
          try {
            compiled = math.compile(expr.text);
            // Check if expression uses variable x — if not, it's a plain equation
            const usesX = /\bx\b/i.test(expr.text);
            if (!usesX) {
              try {
                const v = compiled.evaluate({ ...sliderScope });
                if (typeof v === "number" && !isNaN(v)) {
                  // include Infinity so e.g. "1/0" shows "= Infinity"
                  isPlainEq = true;
                  plainResult = v;
                } else if (v && v.re !== undefined) {
                  isPlainEq = true;
                  plainResult = Math.abs(v.im || 0) < 1e-9 ? v.re : v;
                } else if (typeof v === "object" && v !== null) {
                  isPlainEq = true;
                  plainResult = v.toString();
                }
              } catch(evalErr) {
                // Expression compiled but failed to evaluate (e.g. undefined
                // slider variable). Show the error instead of silent no-output.
                parseErr = evalErr.message;
              }
            }
            if (!isPlainEq && !parseErr) {
              realFn = x => {
                try {
                  const v = compiled.evaluate({ x, ...sliderScope });
                  if (typeof v === "number") return v;
                  if (v && v.re !== undefined) return Math.abs(v.im || 0) < 1e-9 ? v.re : NaN;
                  return NaN;
                } catch(e) { return NaN; }
              };
            }
          } catch(e) { parseErr = e.message; }
        }
      }
      let coeffs = null, coeffErr = null;
      if (compiled && !isPlainEq && !parseErr) {
        // Adaptive DFT: use fewer samples for low term counts, more for high
        const dftN = terms <= 30 ? 512 : terms <= 100 ? 1024 : 2048;
        for (const r of [0.5, 0.1, 0.02]) {
          try {
            const c = computeCoeffs(compiled, center, terms, r, dftN, sliderScope);
            if (c && c.every(isFinite)) { coeffs = c; break; }
          } catch(e) { /* smaller radius reduces singularity influence, improving Cauchy integral stability */ }
        }
        if (!coeffs) coeffErr = "Could not compute \u2014 try a different center";
      }
      const dC = (showDeriv || showDeriv2) && coeffs ? derivCoeffs(coeffs) : null;
      const d2C = showDeriv2 && dC ? derivCoeffs(dC) : null;
      const iC = showInteg && coeffs ? integCoeffs(coeffs) : null;
      return { ...expr, compiled, realFn, parseErr, coeffs, coeffErr,
               dCoeffs: dC, d2Coeffs: d2C, iCoeffs: iC,
               isPlainEq, plainResult, calculusResult };
    });
  }, [expressions, center, terms, showDeriv, showDeriv2, showInteg, sliderScope]);

  const firstData = exprData.find(e => e.visible && e.realFn && e.coeffs);

  const evalResults = useMemo(() => {
    if (!firstData) return {};
    const approx = evalPoly(firstData.coeffs, center, evalX);
    const exact = firstData.realFn(evalX);
    const pctErr = (isFinite(exact) && Math.abs(exact) > 1e-15)
      ? Math.abs((approx - exact) / exact) * 100 : NaN;
    const derivVal = firstData.dCoeffs ? evalPoly(firstData.dCoeffs, center, evalX) : NaN;
    const deriv2Val = firstData.d2Coeffs ? evalPoly(firstData.d2Coeffs, center, evalX) : NaN;
    const integVal = firstData.iCoeffs ? evalPoly(firstData.iCoeffs, center, evalX) : NaN;
    return { approx, exact, pctErr, derivVal, deriv2Val, integVal };
  }, [firstData, center, evalX]);

  const { approx, exact, pctErr, derivVal, deriv2Val, integVal } = evalResults;

  const errColor = !isFinite(pctErr) ? t.textDim
